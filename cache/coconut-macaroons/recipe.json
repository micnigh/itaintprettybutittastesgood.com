              "startIndex": 380,
              "endIndex": 402,
              "textRun": {
                "content": "⅛ tsp cream of tartar\n",
                "textStyle": {}
              }
            }
          ],
          "paragraphStyle": {
            "namedStyleType": "NORMAL_TEXT",
            "direction": "LEFT_TO_RIGHT",
            "indentFirstLine": {
