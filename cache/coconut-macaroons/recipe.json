        "paragraph": {
          "elements": [
            {
              "startIndex": 402,
              "endIndex": 425,
              "textRun": {
                "content": "Dash of salt if wanted\n",
                "textStyle": {}
              }
            }
          ],
          "paragraphStyle": {
            "namedStyleType": "NORMAL_TEXT",
            "direction": "LEFT_TO_RIGHT",
