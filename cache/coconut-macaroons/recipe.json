            {
              "startIndex": 425,
              "endIndex": 437,
              "textRun": {
                "content": "Preparation\n",
                "textStyle": {}
              }
            }
          ],
          "paragraphStyle": {
            "headingId": "h.r6xq7pfkkogo",
            "namedStyleType": "HEADING_3",
            "direction": "LEFT_TO_RIGHT"
          }
        }
      },
      {
        "startIndex": 437,
        "endIndex": 513,
        "paragraph": {
          "elements": [
            {
              "startIndex": 437,
              "endIndex": 513,
              "textRun": {
                "content": "Preheat oven to 350 degrees and set a baking tray with a silicone mat aside\n",
                "textStyle": {}
              }
            }
          ],
          "paragraphStyle": {
            "namedStyleType": "NORMAL_TEXT",
            "direction": "LEFT_TO_RIGHT",
            "indentFirstLine": {
              "magnitude": 18,
              "unit": "PT"
            },
            "indentStart": {
              "magnitude": 36,
              "unit": "PT"
            }
          },
          "bullet": {
            "listId": "kix.jnts3yfq3drn",
            "textStyle": {
              "underline": false
            }
          }
        }
      },
      {
        "startIndex": 513,
        "endIndex": 595,
        "paragraph": {
          "elements": [
            {
              "startIndex": 513,
              "endIndex": 595,
              "textRun": {
                "content": "Beat eggs whites in stand mixer until soft peaks form (just past the foamy stage)\n",
                "textStyle": {}
              }
            }
          ],
          "paragraphStyle": {
            "namedStyleType": "NORMAL_TEXT",
            "direction": "LEFT_TO_RIGHT",
            "indentFirstLine": {
              "magnitude": 18,
              "unit": "PT"
            },
            "indentStart": {
              "magnitude": 36,
              "unit": "PT"
            }
          },
          "bullet": {
            "listId": "kix.jnts3yfq3drn",
            "textStyle": {
              "underline": false
            }
          }
        }
      },
      {
        "startIndex": 595,
        "endIndex": 647,
        "paragraph": {
          "elements": [
            {
              "startIndex": 595,
              "endIndex": 647,
              "textRun": {
                "content": "Add cream of tartar and whip until stiff peaks form\n",
                "textStyle": {}
              }
            }
          ],
          "paragraphStyle": {
            "namedStyleType": "NORMAL_TEXT",
            "direction": "LEFT_TO_RIGHT",
            "indentFirstLine": {
              "magnitude": 18,
              "unit": "PT"
            },
            "indentStart": {
              "magnitude": 36,
              "unit": "PT"
            }
          },
          "bullet": {
            "listId": "kix.jnts3yfq3drn",
            "textStyle": {
              "underline": false
            }
          }
        }
      },
      {
        "startIndex": 647,
        "endIndex": 733,
        "paragraph": {
          "elements": [
            {
              "startIndex": 647,
              "endIndex": 733,
              "textRun": {
                "content": "While the mixer is still going add in sugar slowly until stiff peaks get even stiffer\n",
                "textStyle": {}
              }
            }
          ],
          "paragraphStyle": {
            "namedStyleType": "NORMAL_TEXT",
            "direction": "LEFT_TO_RIGHT",
            "indentFirstLine": {
              "magnitude": 18,
              "unit": "PT"
            },
            "indentStart": {
              "magnitude": 36,
              "unit": "PT"
            }
          },
          "bullet": {
            "listId": "kix.jnts3yfq3drn",
            "textStyle": {
              "underline": false
            }
          }
        }
      },
      {
        "startIndex": 733,
        "endIndex": 799,
        "paragraph": {
          "elements": [
            {
              "startIndex": 733,
              "endIndex": 799,
              "textRun": {
                "content": "Add in almond extract and quickly whip into egg and sugar mixture\n",
                "textStyle": {}
              }
            }
          ],
          "paragraphStyle": {
            "namedStyleType": "NORMAL_TEXT",
            "direction": "LEFT_TO_RIGHT",
            "indentFirstLine": {
              "magnitude": 18,
              "unit": "PT"
            },
            "indentStart": {
              "magnitude": 36,
              "unit": "PT"
            }
          },
          "bullet": {
            "listId": "kix.jnts3yfq3drn",
            "textStyle": {
              "underline": false
            }
          }
        }
      },
      {
        "startIndex": 799,
        "endIndex": 950,
        "paragraph": {
          "elements": [
            {
              "startIndex": 799,
              "endIndex": 950,
              "textRun": {
                "content": "Take the bowl off the stand mixer and hand in fold with a silicone spatula the shredded coconut until combined, try not to over mix or it will deflate\n",
                "textStyle": {}
              }
            }
          ],
          "paragraphStyle": {
            "namedStyleType": "NORMAL_TEXT",
            "direction": "LEFT_TO_RIGHT",
            "indentFirstLine": {
              "magnitude": 18,
              "unit": "PT"
            },
            "indentStart": {
              "magnitude": 36,
              "unit": "PT"
            }
          },
          "bullet": {
            "listId": "kix.jnts3yfq3drn",
            "textStyle": {
              "underline": false
            }
          }
        }
      },
      {
        "startIndex": 950,
        "endIndex": 1002,
        "paragraph": {
          "elements": [
            {
              "startIndex": 950,
              "endIndex": 1002,
              "textRun": {
                "content": "bake 350 degrees for 20 min will golden on the tips\n",
                "textStyle": {}
              }
            }
          ],
          "paragraphStyle": {
            "namedStyleType": "NORMAL_TEXT",
            "direction": "LEFT_TO_RIGHT",
