          "elements": [
            {
              "startIndex": 28,
              "endIndex": 270,
              "textRun": {
                "content": "Ok so your father knows that it is the holiday season (any holiday to be honest) when I break out these cookies. They are achingly sweet and gluten free. You can lessen the sugar content but where is the fun in that?! I love you both dearly.\n",
                "textStyle": {}
              }
            }
          ],
          "paragraphStyle": {
            "namedStyleType": "NORMAL_TEXT",
            "direction": "LEFT_TO_RIGHT"
